# ============================================================
# ExpenseWise AI Agent - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to git!
# ============================================================

# --- App Config ---
APP_ENV=development
APP_PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# --- AWS Config ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# --- AWS Bedrock (Claude) ---
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# --- WhatsApp / Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# --- Meta WhatsApp (Alternative to Twilio) ---
# META_WHATSAPP_TOKEN=your_meta_token
# META_PHONE_NUMBER_ID=your_phone_number_id
# META_VERIFY_TOKEN=your_verify_token

# --- Google Drive / Sheets ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive.file,https://www.googleapis.com/auth/spreadsheets

# --- Dropbox ---
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_REDIRECT_URI=http://localhost:8000/auth/dropbox/callback

# --- OneDrive (Microsoft) ---
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/onedrive/callback

# --- PostgreSQL Database ---
DATABASE_URL=postgresql://expensewise_user:password@localhost:5432/expensewise_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis (for caching / queues) ---
REDIS_URL=redis://localhost:6379/0

# --- LangSmith (AI Observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=expensewise-ai-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- AWS Textract (OCR for receipts) ---
TEXTRACT_REGION=ap-south-1

# --- Scheduler (Daily Summaries) ---
DAILY_SUMMARY_HOUR=20
DAILY_SUMMARY_MINUTE=0
TIMEZONE=Asia/Kolkata

# --- Expense Defaults ---
DEFAULT_CURRENCY=INR
DEFAULT_LANGUAGE=en
